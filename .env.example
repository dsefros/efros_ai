# ===== Core runtime =====
APP_ENV=development
LOG_LEVEL=INFO

# ===== API =====
API_HOST=0.0.0.0
API_PORT=8000

# ===== LLM =====
LLM_BACKEND=local
DEFAULT_MODEL=ministral

# ===== Vector DB / RAG =====
QDRANT_URL=http://localhost:6333
QDRANT_PRODUCT_COLLECTION=rag_product
QDRANT_REGULATORY_COLLECTION=rag_regulatory

# ===== Local model paths =====
MINISTRAL_MODEL_PATH=/models/ministral.gguf
QWEN2_MODEL_PATH=/models/qwen2.gguf
MISTRAL7B_MODEL_PATH=/models/mistral7b.gguf

# ===== Embedding / reranker =====
EMBEDDING_MODEL=BAAI/bge-m3
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# ===== LLM runtime params =====
LLM_N_CTX=4096
LLM_N_THREADS=4
LLM_N_GPU_LAYERS=0
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=512

# ===== RAG search params =====
RAG_TOP_K_PER_COLLECTION=5
RAG_FINAL_TOP_K=8

# ===== Optional domain profiles =====
# DEFAULT_DOMAIN_NAME selects the fallback domain when DOMAIN_PROFILES_JSON is set.
DEFAULT_DOMAIN_NAME=default
# DOMAIN_PROFILES_JSON accepts a JSON object for domain-specific collections and retrieval settings.
DOMAIN_PROFILES_JSON=
