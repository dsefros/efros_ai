# ===== Core runtime =====
APP_ENV=development
LOG_LEVEL=INFO

# ===== API =====
API_HOST=0.0.0.0
API_PORT=8000

# ===== LLM =====
LLM_BACKEND=local
DEFAULT_MODEL=ministral

# ===== Vector DB / RAG =====
QDRANT_URL=http://localhost:6333
QDRANT_PRODUCT_COLLECTION=rag_product
QDRANT_REGULATORY_COLLECTION=rag_regulatory

# ===== Local model paths =====
MINISTRAL_MODEL_PATH=/models/ministral.gguf
QWEN2_MODEL_PATH=/models/qwen2.gguf
MISTRAL7B_MODEL_PATH=/models/mistral7b.gguf

# ===== Embedding / reranker =====
EMBEDDING_MODEL=BAAI/bge-m3
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# ===== LLM runtime params =====
LLM_N_CTX=4096
LLM_N_THREADS=4
LLM_N_GPU_LAYERS=0
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=512

# ===== RAG search params =====
RAG_TOP_K_PER_COLLECTION=5
RAG_FINAL_TOP_K=8

# ===== Optional domain profiles =====
# DEFAULT_DOMAIN_NAME selects the fallback domain when DOMAIN_PROFILES_JSON is set.
DEFAULT_DOMAIN_NAME=default
# DOMAIN_PROFILES_JSON accepts a JSON object for domain-specific collections and retrieval settings.
DOMAIN_PROFILES_JSON=

# ===== Support integrations scaffold =====
REDMINE_ENABLED=false
REDMINE_BASE_URL=https://redmine.example.com
REDMINE_API_KEY=replace-with-redmine-api-key
REDMINE_TARGET_STATUS_ID=150
REDMINE_STATUS_IDS=1,150,5
REDMINE_PROJECT_IDS=10,20

TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=123456:replace-with-telegram-bot-token
TELEGRAM_DEFAULT_CHAT_ID=-1001234567890

HISTORY_PERSISTENCE_ENABLED=false
HISTORY_PERSISTENCE_HOST=localhost
HISTORY_PERSISTENCE_PORT=5432
HISTORY_PERSISTENCE_DATABASE=efros_history
HISTORY_PERSISTENCE_USER=efros
HISTORY_PERSISTENCE_PASSWORD=replace-with-history-db-password
HISTORY_PERSISTENCE_SCHEMA=public
HISTORY_PERSISTENCE_SSL_MODE=prefer
